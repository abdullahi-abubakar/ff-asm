 ```bash
 pytest tests/ -v -m auth --html=reports/auth_report.html --self-contained-html 
 pytest tests/ -v -m contract --html=reports/contract_report.html --self-contained-html 
 pytest tests/ -v -m tenant --html=reports/tenant_report.html --self-contained-html 
 pytest tests/ -v -m crud --html=reports/crud_report.html --self-contained-html 
 pytest tests/ -v -m negative --html=reports/negative_report.html --self-contained-html 
 pytest tests/ -v -m tenant_segregation --html=reports/tenant_segregation_report.html --self-contained-html 
 ```

